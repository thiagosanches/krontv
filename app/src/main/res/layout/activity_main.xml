<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name"
            app:titleTextColor="?attr/colorOnPrimary" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Connection Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/connectionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_bluetooth"
                            android:padding="8dp"
                            android:background="@drawable/circle_primary_bg"
                            app:tint="?attr/colorOnPrimaryContainer" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:text="Bluetooth Connection"
                            android:textSize="20sp"
                            android:textColor="?attr/colorOnSurface" />

                    </LinearLayout>

                    <!-- Connection Status -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical">

                        <View
                            android:id="@+id/statusIndicator"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/status_indicator" />

                        <TextView
                            android:id="@+id/connectionStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Not Connected"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                    <!-- Progress Indicator -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/connectionProgress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:indeterminate="true"
                        android:visibility="gone" />

                    <!-- Buttons -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/connectButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Connect to TV"
                        android:textSize="15sp"
                        app:icon="@drawable/ic_bluetooth" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/testPowerButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Test Power Button"
                        android:enabled="false"
                        android:textSize="15sp"
                        app:icon="@drawable/ic_power"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    
                    <!-- Last Command Status -->
                    <TextView
                        android:id="@+id/lastCommandStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:padding="12dp"
                        android:background="@drawable/circle_secondary_bg"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:visibility="gone"
                        android:textColor="?attr/colorOnSecondaryContainer" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Schedule Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/scheduleCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_schedule"
                            android:padding="8dp"
                            android:background="@drawable/circle_secondary_bg"
                            app:tint="?attr/colorOnSecondaryContainer" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:text="Power Schedule"
                            android:textSize="20sp"
                            android:textColor="?attr/colorOnSurface" />

                    </LinearLayout>

                    <!-- Turn On Time -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="TURN ON TIME"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/turnOnTimeButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="08:00"
                        android:textSize="24sp"
                        android:paddingVertical="20dp"
                        app:icon="@drawable/ic_time"
                        app:iconSize="28dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/enableTurnOnSwitch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Enable Turn ON schedule"
                        android:textSize="15sp"
                        android:textColor="?attr/colorOnSurface" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="20dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Turn Off Time -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TURN OFF TIME"
                        android:textSize="12sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.1"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/turnOffTimeButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="22:00"
                        android:textSize="24sp"
                        android:paddingVertical="20dp"
                        app:icon="@drawable/ic_time"
                        app:iconSize="28dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/enableTurnOffSwitch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Enable Turn OFF schedule"
                        android:textSize="15sp"
                        android:textColor="?attr/colorOnSurface" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/infoCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="2dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="?attr/colorTertiaryContainer">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_info"
                        app:tint="?attr/colorOnTertiaryContainer" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:text="Your TV must be in standby mode (not fully powered off) for the turn ON schedule to work. Enable 'Quick Start' or similar setting in your TV."
                        android:textSize="14sp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="?attr/colorOnTertiaryContainer" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
